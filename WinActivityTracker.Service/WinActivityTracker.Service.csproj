  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\WinActivityTracker.Core\WinActivityTracker.Core.csproj" />
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="10.0.8" />
  </ItemGroup>

</Project>
