[
  { "_comment": "=== Window Title Normalization Rules ===" },
  { "_comment": "Collapses long browser/program titles (e.g. \"GitHub - Firefox\") into short canonical names." },
  { "_comment": "" },
  { "_comment": "Two rule types:" },
  { "_comment": "  1. Fixed replacement: set the title field — window title is replaced with a fixed string." },
  { "_comment": "  2. Regex substitution: set titleRegex + titleReplacement — regex replace on original title." },
  { "_comment": "     e.g. fish title \"~/projects\" matched by ^(\\S+) becomes \"~/projects\"." },
  { "_comment": "  When both are set, fixed replacement (title) takes priority." },
  { "_comment": "" },
  { "_comment": "Fields:" },
  { "_comment": "  process: process name (case-insensitive), e.g. firefox, msedge" },
  { "_comment": "  title: fixed replacement title (optional)" },
  { "_comment": "  titleRegex: regex match pattern (optional)" },
  { "_comment": "  titleReplacement: regex replacement string (optional)" },
  { "_comment": "" },
  { "_comment": "=== Browsers ===" },
  { "process": "firefox",            "title": "Mozilla Firefox" },
  { "process": "msedge",             "title": "Microsoft Edge" },
  { "process": "chrome",             "title": "Google Chrome" },
  { "process": "brave",              "title": "Brave Browser" },
  { "process": "opera",              "title": "Opera Browser" },
  { "_comment": "" },
  { "_comment": "=== Terminals ===" },
  { "process": "WindowsTerminal",    "title": "Windows Terminal" },
  { "process": "wezterm-gui",        "title": "WezTerm" },
  { "process": "alacritty",          "title": "Alacritty" },
  { "process": "fish", "titleRegex": "^(\\S+)", "titleReplacement": "$1" },
  { "process": "bash", "titleRegex": "^(\\S+)", "titleReplacement": "$1" },
  { "process": "zsh",  "titleRegex": "^(\\S+)", "titleReplacement": "$1" },
  { "_comment": "" },
  { "_comment": "=== System ===" },
  { "process": "ApplicationFrameHost", "title": "[UWP App]" }
]
